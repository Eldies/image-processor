{
	"name": "Image Processor devcontainer",

    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
        "ghcr.io/devcontainers/features/python:1": {
            "version": "3.14"
        },
        "ghcr.io/devcontainers-extra/features/poetry:2": {},

        "ghcr.io/devcontainers/features/git:1": {},
    },

    "forwardPorts": [8000],
    "portsAttributes": {
        "8000": { "label": "Backend (FastAPI)" }
    },

    "postCreateCommand": "POETRY_VIRTUALENVS_IN_PROJECT=true poetry install --no-interaction",

    "customizations" : {
        "jetbrains" : {
            "backend" : "PyCharm"
        }
    },

    "mounts": [
        "source=jetbrains_pycharm_config,target=/.jbdevcontainer/config,type=volume"
    ],

    "remoteUser": "vscode"
}
